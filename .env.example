# Froide instance base URL
FROIDE_BASE_URL=https://your-froide.run.app

# Google OAuth2 — create at console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Restrict SSO to a specific Google Workspace domain (leave empty to allow all)
ALLOWED_HD=yourdomain.fi

# Session signing secret (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Froide OAuth2 Application credentials (created in Froide admin > OAuth > Applications)
# Grant type: client_credentials
FROIDE_CLIENT_ID=
FROIDE_CLIENT_SECRET=

# Public URL of this MCP server (Cloud Run service URL after first deploy)
MCP_BASE_URL=https://froide-mcp-xxxx.run.app

# Port (Cloud Run injects this automatically)
PORT=8080
